
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    

    // Itineraries: owners can do anything, others can read if shareEnabled
    match /users/{userId}/itineraries/{itineraryId} {
      allow read: if resource.data.shareEnabled == true;
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Mapping for sharing: public read, owner write/delete
    match /shared_itineraries/{token} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Notifications: owner can read/write, others can create (to send a notif)
    match /users/{userId}/notifications/{notifId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null; // Anyone can send a notification
    }

    // Users: public profile read, owner write
    match /users/{userId} {
      allow read: if true; // Public profiles for search
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Subcollections are still protected mostly by the specific rules above or by owner-only defaults
      match /{allSubcollections=**} {
         allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // In case there are any legacy top-level collections (keeping them but ensuring security)
    match /instants/{instantId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    match /encounters/{encounterId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    match /dishes/{dishId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    match /accommodations/{accommodationId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
    match /stories/{storyId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }
  }
}
